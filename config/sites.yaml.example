# sites.yaml.example — historical seed shape for the artemis sites map.
#
# Post-cutover (artemis@f115198) the authoritative store is Valkey;
# this file is **not** consumed at runtime. It is retained as a
# cold-start reference — useful for replaying entries after a full
# Valkey wipe via `universe sites register <slug> --team <team>...`.
#
# Each top-level key under `sites:` is a site slug (matches the
# sub-domain served by Caddy on cassiopeia, e.g.
# `<site>.freecode.camp`). The `teams:` list enumerates GitHub team
# slugs (within GH_ORG) whose members are authorized to deploy to
# that site.

sites:
  www:
    teams:
      - team-eng
      - team-platform
  learn:
    teams:
      - team-eng
  news:
    teams:
      - team-content
