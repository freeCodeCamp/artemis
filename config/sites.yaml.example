# sites.yaml.example — schema reference for the artemis sites map.
#
# The authoritative store at runtime is Valkey; this file is not
# consumed by the running service. It exists as a schema reference,
# useful when replaying entries after a full Valkey wipe via
# `universe sites register <slug> --team <team>...`.
#
# Each top-level key under `sites:` is a site slug, which becomes the
# sub-domain the deployment serves (e.g. `<site>.<root-domain>`). The
# `teams:` list enumerates GitHub team slugs (within GH_ORG) whose
# members are authorized to deploy to that site.

sites:
  www:
    teams:
      - team-eng
      - team-platform
  learn:
    teams:
      - team-eng
  news:
    teams:
      - team-content
