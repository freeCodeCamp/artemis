# artemis dev env loader.
#
# Contributor path: copy .env.example → .env, fill values, then `direnv allow`.
# Operator path: set SECRETS_DIR to a directory of sops *.env.enc envelopes
# (top-level glob is decrypted + loaded). For per-operator envelope paths
# beyond that glob, layer a .envrc.local (gitignored).

use_sops() {
  local path="$1"
  local type="${2:-dotenv}"
  if [ -f "$path" ]; then
    local decrypted
    decrypted=$(sops -d --input-type "$type" --output-type "$type" "$path" 2>&1) || {
      log_error "sops decrypt failed for $path"
      return
    }
    eval "$(echo "$decrypted" | direnv dotenv bash /dev/stdin)"
    watch_file "$path"
  fi
}

if [ -n "${SECRETS_DIR:-}" ] && [ -d "$SECRETS_DIR" ]; then
  for envelope in "$SECRETS_DIR"/*.env.enc; do
    [ -f "$envelope" ] && use_sops "$envelope"
  done
fi

source_env_if_exists .envrc.local
dotenv_if_exists .env
